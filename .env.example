# Local development. Production must use NODE_ENV=production and DATABASE_URL.
NODE_ENV=development
PORT=3001
DATABASE_PATH=data/astralis.db

# Hostinger MySQL example:
# DATABASE_URL=mysql://DB_USER:URL_ENCODED_PASSWORD@DB_HOST:3306/DB_NAME
# DATABASE_SSL=true
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-with-at-least-32-random-characters

# Closed by default in production. Enable only when public signup is intended.
ALLOW_REGISTRATION=false

# One-time bootstrap. Remove ADMIN_INITIAL_PASSWORD after the first successful start.
# ADMIN_EMAIL=owner@example.com
# ADMIN_INITIAL_PASSWORD=use-a-unique-password-of-14-or-more-characters
