{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "isolatedModules": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "server",
    "outDir": "build/server",
    "sourceMap": true,
    "declaration": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/**/*.test.ts"]
}
